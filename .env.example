# ── DeepSeek API ──────────────────────────────────────────────────────────────
# 在 Render Dashboard > Environment 中设置，不要提交到 GitHub
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 模型（可选，以下为默认值）
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# ── 服务配置 ───────────────────────────────────────────────────────────────────
PORT=3000

# ── 数据存储路径 ───────────────────────────────────────────────────────────────
# 本地开发: ./data/sessions
# Render 部署: /var/data/sessions  (需在 Render 挂载 Disk 到 /var/data)
DATA_DIR=./data/sessions
